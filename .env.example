# =============================================================================
# ML Price Hunter — copie para .env e preencha os valores reais.
# NUNCA versione o .env com credenciais reais.
# =============================================================================

# --- PostgreSQL (mesmo da infra/) ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=airflow
DB_PASSWORD=airflow
DB_NAME=airflow

# --- Mercado Livre ---
# Termo de busca que o n8n vai passar para a API
ML_SEARCH_QUERY=rtx 4070
ML_SEARCH_LIMIT=5

# --- Regra de negócio ---
# Percentual de queda que dispara alerta (ex: -10.0 = queda de 10%)
ALERT_THRESHOLD_PCT=-10.0

# --- Telegram (preencha para receber alertas) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
