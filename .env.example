# =============================================================================
# Crypto Price Hunter — copie para .env e preencha os valores reais.
# NUNCA versione o .env com credenciais reais.
# =============================================================================

# --- PostgreSQL (mesmo da infra/) ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=airflow
DB_PASSWORD=airflow
DB_NAME=airflow

# --- CoinGecko (sem auth — API pública gratuita) ---
# IDs disponíveis em: https://api.coingecko.com/api/v3/coins/list
CRYPTO_IDS=bitcoin,ethereum,solana,cardano,chainlink
CRYPTO_LIMIT=5

# --- Regra de negócio ---
# Percentual de queda que dispara alerta (ex: -10.0 = queda de 10%)
ALERT_THRESHOLD_PCT=-10.0

# --- Telegram (preencha para receber alertas) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
