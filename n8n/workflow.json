{
  "name": "ML Price Hunter — Monitor de Preços",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "hours", "hoursInterval": 1 }]
        }
      },
      "id": "node-schedule-trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "a1",
              "name": "searchQuery",
              "value": "={{ $env.ML_SEARCH_QUERY || 'rtx 4070' }}",
              "type": "string"
            },
            {
              "id": "a2",
              "name": "limit",
              "value": 5,
              "type": "number"
            },
            {
              "id": "a3",
              "name": "appId",
              "value": "={{ $env.ML_APP_ID }}",
              "type": "string"
            },
            {
              "id": "a4",
              "name": "appSecret",
              "value": "={{ $env.ML_APP_SECRET }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "node-set",
      "name": "Set Search Params",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.mercadolibre.com/oauth/token",
        "sendBody": true,
        "contentType": "form-urlencoded",
        "bodyParameters": {
          "parameters": [
            { "name": "grant_type",    "value": "client_credentials" },
            { "name": "client_id",     "value": "={{ $json.appId }}" },
            { "name": "client_secret", "value": "={{ $json.appSecret }}" }
          ]
        },
        "options": {}
      },
      "id": "node-get-token",
      "name": "Get ML Token",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "b1",
              "name": "accessToken",
              "value": "={{ $json.access_token }}",
              "type": "string"
            },
            {
              "id": "b2",
              "name": "searchQuery",
              "value": "={{ $('Set Search Params').first().json.searchQuery }}",
              "type": "string"
            },
            {
              "id": "b3",
              "name": "limit",
              "value": "={{ $('Set Search Params').first().json.limit }}",
              "type": "number"
            }
          ]
        },
        "options": {}
      },
      "id": "node-set-token",
      "name": "Store Token",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [900, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.mercadolibre.com/sites/MLB/search",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $json.accessToken }}"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "q",     "value": "={{ $json.searchQuery }}" },
            { "name": "limit", "value": "={{ $json.limit }}" }
          ]
        },
        "options": {}
      },
      "id": "node-http-ml-search",
      "name": "Search MercadoLivre",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json;\nconst rawItems = (body.results || []).slice(0, 5);\nconst items = rawItems.map(item => ({\n  id: item.id,\n  title: item.title,\n  price: item.price,\n  original_price: item.original_price || null,\n  currency_id: item.currency_id || 'BRL',\n  permalink: item.permalink,\n  seller: { id: item.seller?.id || null, nickname: item.seller?.nickname || '' }\n}));\nreturn [{ json: { items, searchQuery: $('Store Token').first().json.searchQuery } }];"
      },
      "id": "node-code-extract",
      "name": "Extract Items",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://price-monitor:8001/webhook/analyze",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ items: $json.items, query: $json.searchQuery }) }}",
        "options": {}
      },
      "id": "node-http-analyze",
      "name": "Analyze Prices",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1560, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "c1",
              "leftValue": "={{ $json.has_alert }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-if-alert",
      "name": "Has Alert?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1780, 300]
    },
    {
      "parameters": {
        "chatId": "={{ $env.TELEGRAM_CHAT_ID }}",
        "text": "={{ $json.alerts.map(a => '🔴 *' + a.title + '*\\nAntes: R$ ' + a.previous_price + ' → Agora: R$ ' + a.current_price + ' (' + a.variation_pct + '%)\\n' + a.permalink).join('\\n\\n') }}",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "id": "node-telegram-send",
      "name": "Send Telegram Alert",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [2000, 180],
      "credentials": {
        "telegramApi": { "id": "telegram-credentials", "name": "Telegram Bot" }
      }
    },
    {
      "parameters": {},
      "id": "node-noop",
      "name": "No Operation",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [2000, 420]
    }
  ],
  "connections": {
    "Schedule Trigger":   { "main": [[{ "node": "Set Search Params",  "type": "main", "index": 0 }]] },
    "Set Search Params":  { "main": [[{ "node": "Get ML Token",       "type": "main", "index": 0 }]] },
    "Get ML Token":       { "main": [[{ "node": "Store Token",        "type": "main", "index": 0 }]] },
    "Store Token":        { "main": [[{ "node": "Search MercadoLivre","type": "main", "index": 0 }]] },
    "Search MercadoLivre":{ "main": [[{ "node": "Extract Items",      "type": "main", "index": 0 }]] },
    "Extract Items":      { "main": [[{ "node": "Analyze Prices",     "type": "main", "index": 0 }]] },
    "Analyze Prices":     { "main": [[{ "node": "Has Alert?",         "type": "main", "index": 0 }]] },
    "Has Alert?":         { "main": [
      [{ "node": "Send Telegram Alert", "type": "main", "index": 0 }],
      [{ "node": "No Operation",        "type": "main", "index": 0 }]
    ]}
  },
  "pinData": {},
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true
  },
  "staticData": null,
  "tags": [{ "id": "tag-price-monitor", "name": "price-monitor" }],
  "triggerCount": 1,
  "versionId": "2"
}
